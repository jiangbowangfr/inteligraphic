VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 1000 1000 ) ;

REGIONS 2 ;
  - R_LEFT ( 0 0 ) ( 500 1000 ) ;
  - R_RIGHT ( 500 0 ) ( 1000 1000 ) ;
END REGIONS

COMPONENTS 4 ;
  - u_left0 TILE + REGION R_LEFT + PLACED ( 100 100 ) N ;
  - u_left1 BLK + REGION R_LEFT + PLACED ( 200 600 ) N ;
  - u_right0 TILE + REGION R_RIGHT + PLACED ( 700 100 ) N ;
  - u_right1 BLK + REGION R_RIGHT + PLACED ( 600 600 ) N ;
END COMPONENTS

END DESIGN

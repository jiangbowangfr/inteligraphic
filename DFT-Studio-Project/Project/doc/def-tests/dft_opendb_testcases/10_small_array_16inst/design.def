VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 600 600 ) ;

COMPONENTS 16 ;
  - u01 T10 + PLACED ( 100 100 ) E ;
  - u02 T10 + PLACED ( 200 100 ) S ;
  - u03 T10 + PLACED ( 300 100 ) W ;
  - u04 T10 + PLACED ( 400 100 ) N ;
  - u05 T10 + PLACED ( 100 200 ) E ;
  - u06 T10 + PLACED ( 200 200 ) S ;
  - u07 T10 + PLACED ( 300 200 ) W ;
  - u08 T10 + PLACED ( 400 200 ) N ;
  - u09 T10 + PLACED ( 100 300 ) E ;
  - u10 T10 + PLACED ( 200 300 ) S ;
  - u11 T10 + PLACED ( 300 300 ) W ;
  - u12 T10 + PLACED ( 400 300 ) N ;
  - u13 T10 + PLACED ( 100 400 ) E ;
  - u14 T10 + PLACED ( 200 400 ) S ;
  - u15 T10 + PLACED ( 300 400 ) W ;
  - u16 T10 + PLACED ( 400 400 ) N ;
END COMPONENTS

REGIONS 1 ;
  - GRID ( 50 50 ) ( 500 50 ) ( 500 500 ) ( 50 500 ) ;
END REGIONS

PINS 1 ;
  - PIN0 + NET N_PIN0 + DIRECTION INPUT + USE SIGNAL
    + PLACED ( 0 250 ) N + LAYER metal1 ( 0 0 ) ( 10 10 ) ;
END PINS

NETS 1 ;
  - N_PIN0 ( PIN PIN0 ) ;
END NETS

END DESIGN

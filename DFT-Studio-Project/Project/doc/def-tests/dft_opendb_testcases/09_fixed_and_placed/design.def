VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 800 600 ) ;

COMPONENTS 4 ;
  - u_fix FIXBLK + FIXED ( 50 50 ) N ;
  - u_plc0 PLCBLK + PLACED ( 300 100 ) N ;
  - u_plc1 PLCBLK + PLACED ( 300 200 ) S ;
  - u_plc2 PLCBLK + PLACED ( 300 300 ) FN ;
END COMPONENTS

END DESIGN

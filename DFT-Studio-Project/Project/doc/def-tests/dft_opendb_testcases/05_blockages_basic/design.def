VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 1000 1000 ) ;

COMPONENTS 2 ;
  - u_core0 CORE + PLACED ( 100 100 ) N ;
  - u_mem0 MEM + PLACED ( 700 600 ) N ;
END COMPONENTS

BLOCKAGES 3 ;
  - PLACEMENT + RECT ( 300 300 ) ( 500 500 ) ;
  - PLACEMENT + RECT ( 600 100 ) ( 850 250 ) ;
  - PLACEMENT + RECT ( 100 700 ) ( 400 900 ) ;
END BLOCKAGES

END DESIGN

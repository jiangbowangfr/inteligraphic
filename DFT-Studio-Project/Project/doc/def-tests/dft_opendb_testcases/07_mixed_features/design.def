VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 1200 1200 ) ;

COMPONENTS 4 ;
  - u_dsp DSP + REGION R_TOP + PLACED ( 100 700 ) N ;
  - u_sram SRAM + REGION R_TOP + FIXED ( 700 650 ) N ;
  - u_ctrl0 CTRL + REGION R_BOT + PLACED ( 200 200 ) FN ;
  - u_ctrl1 CTRL + REGION R_BOT + PLACED ( 400 250 ) N ;
END COMPONENTS

REGIONS 2 ;
  - R_TOP ( 0 600 ) ( 1200 600 ) ( 1200 1200 ) ( 0 1200 ) ;
  - R_BOT ( 0 0 ) ( 1200 0 ) ( 1200 600 ) ( 0 600 ) ;
END REGIONS

BLOCKAGES 2 ;
  - PLACEMENT + RECT ( 500 500 ) ( 750 650 ) ;
  - PLACEMENT + RECT ( 200 200 ) ( 350 350 ) ;
END BLOCKAGES

PINS 2 ;
  - PIN_RST + NET N_PIN_RST + DIRECTION INPUT + USE RESET
    + PLACED ( 0 50 ) N + LAYER metal1 ( 0 0 ) ( 10 10 ) ;
  - PIN_DBG + NET N_PIN_DBG + DIRECTION INOUT + USE SIGNAL
    + PLACED ( 1200 1100 ) N + LAYER metal2 ( 0 0 ) ( 10 10 ) ;
END PINS

NETS 2 ;
  - N_PIN_RST ( PIN PIN_RST ) ;
  - N_PIN_DBG ( PIN PIN_DBG ) ;
END NETS

END DESIGN

VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 1000 1000 ) ;

COMPONENTS 2 ;
  - u0 BLK1 + PLACED ( 200 200 ) N ;
  - u1 BLK2 + PLACED ( 600 400 ) N ;
END COMPONENTS

PINS 3 ;
  - PIN_IN0 + NET N_PIN_IN0 + DIRECTION INPUT + USE SIGNAL
    + PLACED ( 0 200 ) N + LAYER metal1 ( 0 0 ) ( 10 10 ) ;
  - PIN_OUT0 + NET N_PIN_OUT0 + DIRECTION OUTPUT + USE SIGNAL
    + PLACED ( 1000 600 ) N + LAYER metal2 ( 0 0 ) ( 10 10 ) ;
  - PIN_CLK + NET N_PIN_CLK + DIRECTION INPUT + USE CLOCK
    + PLACED ( 0 800 ) N + LAYER metal1 ( 0 0 ) ( 10 10 ) ;
END PINS

NETS 3 ;
  - N_PIN_IN0 ( PIN PIN_IN0 ) ;
  - N_PIN_OUT0 ( PIN PIN_OUT0 ) ;
  - N_PIN_CLK ( PIN PIN_CLK ) ;
END NETS

END DESIGN

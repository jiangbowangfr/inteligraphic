VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 1600 900 ) ;

COMPONENTS 8 ;
  - u0 MBIG + PLACED ( 100 100 ) N ;
  - u1 MBIG + PLACED ( 400 100 ) S ;
  - u2 MSMALL + PLACED ( 100 400 ) E ;
  - u3 MSMALL + PLACED ( 400 400 ) W ;
  - u4 MBIG + PLACED ( 700 100 ) FN ;
  - u5 MBIG + PLACED ( 1000 100 ) FS ;
  - u6 MSMALL + PLACED ( 700 400 ) FE ;
  - u7 MSMALL + PLACED ( 1000 400 ) FW ;
END COMPONENTS

END DESIGN

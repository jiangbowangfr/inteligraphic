VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN TOP ;

UNITS DISTANCE MICRONS 1000 ;

DIEAREA ( 0 0 ) ( 1200 800 ) ;

COMPONENTS 4 ;
  - ua1 A1 + PLACED ( 100 100 ) N ;
  - ua2 A2 + PLACED ( 200 300 ) N ;
  - ub1 B1 + PLACED ( 500 100 ) N ;
  - ub2 B2 + PLACED ( 700 250 ) N ;
END COMPONENTS

END DESIGN

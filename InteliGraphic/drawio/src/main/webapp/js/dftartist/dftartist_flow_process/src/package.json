{
        "name": "dft-flow-process",
        "version": "0.1.0",
        "private": true,
        "scripts": {
                "dev": "vite",
                "build:load": "vite build --config vite.load.config.js",
                "build:status": "vite build --config vite.status.config.js",
                "build:analysis": "vite build --config vite.analysis.config.js",
                "build:preview": "vite build --config vite.preview.config.js",
                "build": "vite build --config vite.load.config.js && vite build --config vite.status.config.js && vite build --config vite.analysis.config.js && vite build --config vite.preview.config.js",
                "preview": "vite preview"
        },
        "dependencies": {
                "@ant-design/charts": "^2.6.7",
                "antd": "^5.27.4",
                "prismjs": "^1.30.0",
                "react": "^19.1.1",
                "react-dom": "^19.1.1",
                "yaml": "^2.8.1"
        },
        "devDependencies": {
                "@vitejs/plugin-react": "^5.0.3",
                "vite": "^7.1.7"
        }
}
